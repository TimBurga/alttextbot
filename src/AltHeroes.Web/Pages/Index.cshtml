@page
@model AltHeroes.Web.Pages.IndexModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark light" />
    <title>AltHeroes — Check your alt text score</title>
    <meta name="description" content="See how consistently you add alt text to your Bluesky images. Check your AltHeroes score — Bronze, Silver, Gold, or Hero tier.">
    <meta property="og:title" content="AltHeroes — Check your alt text score">
    <meta property="og:description" content="See how consistently you add alt text to your Bluesky images.">
    <meta property="og:type" content="website">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/shared.css">
    <script>(function(){var t=localStorage.getItem('altheroes_theme')||(matchMedia('(prefers-color-scheme:light)').matches?'light':'dark');document.documentElement.setAttribute('data-theme',t);})();</script>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            color-scheme: dark;
            --bg: #0a0c12;
            --surface: #13151f;
            --border: #252836;
            --text: #e8eaf2;
            --muted: #6b7280;
            --accent: #6366f1;
            --hero: #a855f7;
        }

        [data-theme="light"] {
            color-scheme: light;
            --bg: #f0f2f8;
            --surface: #ffffff;
            --border: #d4d9ea;
            --text: #111827;
            --muted: #6b7280;
        }

        body {
            font-family: 'Plus Jakarta Sans', system-ui, -apple-system, sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            position: relative;
        }

        /* Ambient glow behind the hero content */
        body::after {
            content: '';
            position: fixed;
            width: 900px;
            height: 700px;
            background: radial-gradient(ellipse at center, rgba(99,102,241,0.13) 0%, rgba(168,85,247,0.06) 45%, transparent 70%);
            top: 50%;
            left: 50%;
            transform: translate(-50%, -55%);
            pointer-events: none;
            z-index: 0;
        }

        .hero {
            position: relative;
            z-index: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            width: 100%;
            max-width: 520px;
        }

        .logo {
            font-size: 3.25rem;
            font-weight: 900;
            letter-spacing: -0.04em;
            line-height: 1;
            margin-bottom: 0.75rem;
            background: linear-gradient(135deg, #818cf8 0%, #a855f7 55%, #ec4899 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .tagline {
            color: var(--muted);
            font-size: 1rem;
            font-weight: 400;
            line-height: 1.6;
            margin-bottom: 2rem;
            max-width: 360px;
        }

        form {
            display: flex;
            gap: 0.5rem;
            width: 100%;
            margin-bottom: 1.5rem;
        }

        input[type="text"] {
            flex: 1;
            background: var(--surface);
            border: 1.5px solid var(--border);
            border-radius: 12px;
            color: var(--text);
            font-family: inherit;
            font-size: 0.95rem;
            outline: none;
            padding: 0.8rem 1.1rem;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        input[type="text"]:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(99,102,241,0.15);
        }

        input[type="text"]::placeholder { color: var(--muted); }

        button {
            background: linear-gradient(135deg, var(--accent), var(--hero));
            border: none;
            border-radius: 12px;
            color: #fff;
            cursor: pointer;
            font-family: inherit;
            font-size: 0.95rem;
            font-weight: 600;
            padding: 0.8rem 1.5rem;
            transition: opacity 0.15s, transform 0.15s, box-shadow 0.15s;
            white-space: nowrap;
            box-shadow: 0 4px 15px rgba(99,102,241,0.3);
        }

        button:hover {
            opacity: 0.9;
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(99,102,241,0.4);
        }

        button:active { transform: translateY(0); }

        /* Tier preview chips */
        .tier-preview {
            display: flex;
            gap: 0.45rem;
            flex-wrap: wrap;
            justify-content: center;
        }

        .tier-chip {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.25rem;
            padding: 0.3rem 0.7rem;
            border-radius: 9999px;
            font-size: 0.78rem;
            font-weight: 600;
            border: 1px solid;
            width: 9rem;
            height: 1.75rem;      /* fixed height keeps all chips uniform regardless of emoji size */
            white-space: nowrap;
        }

        .tier-chip.bronze { color: #cd7f32; border-color: rgba(205,127,50,0.35);  background: rgba(205,127,50,0.08);  }
        .tier-chip.silver { color: #94a3b8; border-color: rgba(148,163,184,0.35); background: rgba(148,163,184,0.08); }
        .tier-chip.gold   { color: #f59e0b; border-color: rgba(245,158,11,0.35);  background: rgba(245,158,11,0.08);  }
        .tier-chip.hero   { color: #a855f7; border-color: rgba(168,85,247,0.35);  background: rgba(168,85,247,0.08);  }

        /* ── Animated logo gradient shimmer ─────────────────── */
        @@keyframes logoShimmer {
            0%   { background-position: 0% center; }
            100% { background-position: 200% center; }
        }

        .logo {
            background-size: 200% auto;
            animation: logoShimmer 5s linear infinite;
        }

        /* ── Staggered tier chip entrance ───────────────────── */
        @@keyframes chipRise {
            from { opacity: 0; transform: translateY(8px) scale(0.94); }
            to   { opacity: 1; transform: translateY(0)   scale(1);    }
        }

        .tier-chip {
            opacity: 0;
            animation: chipRise 0.4s ease forwards;
        }

        .tier-chip:nth-child(1) { animation-delay: 0.50s; }
        .tier-chip:nth-child(2) { animation-delay: 0.65s; }
        .tier-chip:nth-child(3) { animation-delay: 0.80s; }
        .tier-chip:nth-child(4) { animation-delay: 0.95s; }

        /* ── Reduced motion ─────────────────────────────────── */
        @@media (prefers-reduced-motion: reduce) {
            .logo       { animation: none; }
            .tier-chip  { animation: none !important; opacity: 1; }
        }

        /* ── Theme toggle (floating, top-right) ─────────── */
        .theme-toggle {
            position: fixed;
            top: 1rem;
            right: 1rem;
            z-index: 10;
            width: auto;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 8px;
            color: var(--muted);
            cursor: pointer;
            padding: 0.4rem 0.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            line-height: 1;
            transition: border-color 0.15s, color 0.15s;
        }

        .theme-toggle:hover { border-color: var(--accent); color: var(--accent); }

        @@media (max-width: 480px) {
            form { flex-direction: column; }
            button { width: 100%; }
            .logo { font-size: 2.5rem; }
        }
    </style>
</head>
<body class="dot-grid">
    <button class="theme-toggle" onclick="toggleTheme()" aria-label="Toggle theme">
        <svg class="sun" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        <svg class="moon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
    </button>

    <main>
    <div class="hero">
        <h1 class="logo">AltHeroes</h1>
        <p class="tagline">See how consistently you add alt text to your Bluesky images.</p>

        <form method="get" action="/score">
            <label for="q" class="sr-only">Bluesky handle or DID</label>
            <input id="q" type="text" name="q" placeholder="handle.bsky.social or did:plc:…"
                   value="@Model.Q" autocomplete="off" autofocus />
            <button type="submit">Check</button>
        </form>

        <div class="tier-preview">
            <span class="tier-chip bronze"><span aria-hidden="true">🥉</span> Bronze · ≥60%</span>
            <span class="tier-chip silver"><span aria-hidden="true">🥈</span> Silver · ≥75%</span>
            <span class="tier-chip gold"><span aria-hidden="true">🥇</span> Gold · ≥85%</span>
            <span class="tier-chip hero"><span aria-hidden="true">👑</span> Hero · ≥95%</span>
        </div>
    </div>
    </main>

    <script src="/js/shared.js" defer></script>
</body>
</html>
