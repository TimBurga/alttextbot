@page
@model AltTextBot.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Home";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <h1 class="display-4">Alt Heroes</h1>
            <p class="lead">Encouraging better accessibility on Bluesky, one post at a time.</p>
            <p>Users who consistently add alt text to their images earn tiered labels: Bronze, Silver, Gold, and Hero.</p>
            <p><a href="https://bsky.app/profile/altheroes.bsky.social" target="_blank" rel="noopener noreferrer">Like our profile on Bluesky</a> to subscribe and start earning labels.</p>
            <hr />
            <h2 class="h4">Look up a user</h2>
            <form method="get" action="/user/lookup" class="mt-3">
                <div class="input-group input-group-lg justify-content-center mx-auto" style="max-width: 500px;">
                    <input type="text" name="handle" class="form-control" placeholder="handle.bsky.social" required autocomplete="off" />
                    <button class="btn btn-primary" type="submit">Search</button>
                </div>
            </form>
            <div class="mt-5">
                <h3 class="h5">Label Tiers</h3>
                <table class="table table-bordered mx-auto" style="max-width:400px;">
                    <caption class="visually-hidden">Label tiers and minimum alt text score requirements</caption>
                    <thead class="table-dark">
                        <tr><th>Label</th><th>Min Score</th></tr>
                    </thead>
                    <tbody>
                        <tr><td>&#x1F3C6; Hero</td><td>95%+</td></tr>
                        <tr><td>&#x1F947; Gold</td><td>80%+</td></tr>
                        <tr><td>&#x1F948; Silver</td><td>60%+</td></tr>
                        <tr><td>&#x1F949; Bronze</td><td>40%+</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
