<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark light" />
    <title>@ViewData["Title"] — AltHeroes Admin</title>
    <script>(function(){var t=localStorage.getItem('altheroes_theme')||(matchMedia('(prefers-color-scheme:light)').matches?'light':'dark');document.documentElement.setAttribute('data-theme',t);})();</script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/shared.css">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            color-scheme: dark;
            --bg: #0f1117;
            --surface: #1a1d27;
            --border: #2a2d3a;
            --text: #e2e4ed;
            --muted: #6b7280;
            --accent: #6366f1;
            --accent-hover: #818cf8;
            --danger: #ef4444;
            --danger-hover: #f87171;
            --success: #22c55e;
            --warning: #f59e0b;
            --none: #6b7280;
            --bronze: #cd7f32;
            --silver: #94a3b8;
            --gold: #f59e0b;
            --hero: #a855f7;
        }

        body {
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            font-size: 14px;
            line-height: 1.5;
        }

        header {
            position: sticky;
            top: 0;
            z-index: 100;
            background: rgba(10, 12, 18, 0.85);
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            border-bottom: 1px solid var(--border);
            padding: 0 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 52px;
        }

        header .brand {
            font-weight: 800;
            font-size: 1rem;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 0.35rem;
        }

        header .brand .brand-name {
            background: linear-gradient(135deg, var(--accent), var(--hero));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        header .brand .brand-label {
            color: var(--muted);
            font-size: 0.82rem;
            font-weight: 500;
        }

        header nav { display: flex; align-items: center; gap: 1rem; }

        header nav form { margin: 0; }

        header nav button {
            background: transparent;
            border: 1px solid var(--border);
            color: var(--muted);
            cursor: pointer;
            padding: 0.3rem 0.75rem;
            border-radius: 6px;
            font-size: 13px;
            transition: border-color 0.15s, color 0.15s;
        }

        header nav button:hover { border-color: var(--text); color: var(--text); }

        main { padding: 2rem 1.5rem; max-width: 1200px; margin: 0 auto; }

        @@media (max-width: 600px) {
            main { padding: 1.25rem 1rem; }
            header { padding: 0 1rem; }
        }

        h1 { font-size: 1.4rem; font-weight: 600; margin-bottom: 1.5rem; color: var(--text); }

        .toast-container {
            position: fixed;
            bottom: 1.5rem;
            right: 1.5rem;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
            z-index: 100;
        }

        .toast {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 0.75rem 1rem;
            font-size: 13px;
            opacity: 0;
            transform: translateY(8px);
            transition: opacity 0.2s, transform 0.2s;
            max-width: 320px;
        }

        .toast.show { opacity: 1; transform: translateY(0); }
        .toast.success { border-color: var(--success); color: var(--success); }
        .toast.error { border-color: var(--danger); color: var(--danger); }

        /* ── Light theme ─────────────────────────────────── */
        [data-theme="light"] {
            color-scheme: light;
            --bg: #f4f5f9;
            --surface: #ffffff;
            --border: #dde1ec;
            --text: #1a1d27;
            --muted: #6b7280;
        }

        [data-theme="light"] header {
            background: rgba(244, 245, 249, 0.88);
        }

        /* ── Theme toggle button ─────────────────────────── */
        .theme-toggle {
            background: transparent;
            border: 1px solid var(--border);
            border-radius: 6px;
            color: var(--muted);
            cursor: pointer;
            padding: 0.3rem 0.4rem;
            display: flex;
            align-items: center;
            justify-content: center;
            line-height: 1;
            transition: border-color 0.15s, color 0.15s;
        }

        .theme-toggle:hover { border-color: var(--text); color: var(--text); }

    </style>
    <script src="/js/shared.js" defer></script>
</head>
<body>
<header>
    <a class="brand" href="/admin"><span class="brand-name">AltHeroes</span><span class="brand-label">Admin</span></a>
    <nav>
        <button class="theme-toggle" onclick="toggleTheme()" aria-label="Toggle theme">
            <svg class="sun" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
            <svg class="moon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <form method="post" action="/admin/logout">
                @Html.AntiForgeryToken()
                <button type="submit">Sign out</button>
            </form>
        }
    </nav>
</header>

<main>
    @RenderBody()
</main>

<div class="toast-container" id="toasts"></div>

<script>
function toast(msg, type = 'success') {
    const el = document.createElement('div');
    el.className = `toast ${type}`;
    el.textContent = msg;
    document.getElementById('toasts').appendChild(el);
    requestAnimationFrame(() => { requestAnimationFrame(() => el.classList.add('show')); });
    setTimeout(() => {
        el.classList.remove('show');
        setTimeout(() => el.remove(), 250);
    }, 3000);
}
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
