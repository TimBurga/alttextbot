@page
@model AltTextBot.Web.Pages.Admin.SubscribersModel
@{
    ViewData["Title"] = "Subscribers";
}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>Subscribers</h3>
        <a href="/admin" class="btn btn-outline-secondary btn-sm">&#8592; Dashboard</a>
    </div>
    @if (!Model.Subscribers.Items.Any())
    {
        <p class="text-muted">No subscribers yet.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th style="max-width: 220px;">Handle</th>
                        <th>DID</th>
                        <th>Status</th>
                        <th>Subscribed</th>
                        <th>Last Scored (UTC)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var sub in Model.Subscribers.Items)
                    {
                        <tr>
                            <td style="max-width: 220px;">
                                <a href="/admin/subscribers/@sub.Did"
                                   class="d-inline-block text-truncate w-100"
                                   title="@sub.Handle">@sub.Handle</a>
                            </td>
                            <td><small class="text-muted">@sub.Did</small></td>
                            <td>
                                @if (sub.Status == AltTextBot.Domain.Enums.SubscriberStatus.Active)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Deactivated</span>
                                }
                            </td>
                            <td>@sub.SubscribedAt.ToString("yyyy-MM-dd")</td>
                            <td>@(sub.LastScoredAt?.ToString("yyyy-MM-dd HH:mm") ?? "Never")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @{
        var total = Model.Subscribers.TotalCount;
        var pages = (int)Math.Ceiling(total / (double)Model.Subscribers.PageSize);
        var currentPage = Model.Subscribers.Page;
    }
    @if (pages > 1)
    {
        <nav aria-label="Subscriber list pagination">
            <ul class="pagination">
                @if (currentPage > 1)
                {
                    <li class="page-item"><a class="page-link" href="?page=@(currentPage - 1)">Previous</a></li>
                }
                @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(pages, currentPage + 2); i++)
                {
                    @if (i == currentPage)
                    {
                        <li class="page-item active"><span class="page-link">@i</span></li>
                    }
                    else
                    {
                        <li class="page-item"><a class="page-link" href="?page=@i">@i</a></li>
                    }
                }
                @if (currentPage < pages)
                {
                    <li class="page-item"><a class="page-link" href="?page=@(currentPage + 1)">Next</a></li>
                }
            </ul>
        </nav>
    }
</div>
