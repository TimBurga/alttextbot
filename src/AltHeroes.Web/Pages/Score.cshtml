@page "/score"
@model AltHeroes.Web.Pages.ScoreModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark light" />
    <title>AltHeroes — @(Model.Q ?? "Score")</title>
    <script>(function(){var t=localStorage.getItem('altheroes_theme')||(matchMedia('(prefers-color-scheme:light)').matches?'light':'dark');document.documentElement.setAttribute('data-theme',t);})();</script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            color-scheme: dark;
            --bg: #0a0c12;
            --surface: #1a1d27;
            --surface2: #22263a;
            --border: #2a2d3a;
            --text: #e2e4ed;
            --muted: #6b7280;
            --accent: #6366f1;
            --bronze: #cd7f32;
            --silver: #94a3b8;
            --gold: #f59e0b;
            --hero: #a855f7;
        }

        body {
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            font-size: 14px;
        }

        /* Subtle dot-grid background texture — matches landing page */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background-image: radial-gradient(circle, rgba(99,102,241,0.09) 1px, transparent 1px);
            background-size: 28px 28px;
            pointer-events: none;
            z-index: 0;
        }

        [data-theme="light"] body::before {
            background-image: radial-gradient(circle, rgba(99,102,241,0.13) 1px, transparent 1px);
        }

        /* ── Tier-reactive page background ──────────────── */
        #bg-glow {
            position: fixed;
            inset: 0;
            pointer-events: none;
            z-index: -1;
            opacity: 0;
            transition: opacity 1.8s ease;
        }

        /* ── Header ─────────────────────────────────────── */
        header {
            position: sticky;
            top: 0;
            z-index: 100;
            background: rgba(10, 12, 18, 0.82);
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            border-bottom: 1px solid var(--border);
            padding: 0 1.5rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            height: 52px;
        }

        [data-theme="light"] header {
            background: rgba(240, 242, 248, 0.88);
        }

        .brand {
            font-weight: 800;
            font-size: 1.1rem;
            text-decoration: none;
            background: linear-gradient(135deg, var(--accent), var(--hero));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .header-query {
            flex: 1;
            min-width: 0;
            color: var(--muted);
            font-size: 0.85rem;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        /* ── Main layout ─────────────────────────────────── */
        main {
            max-width: 900px;
            margin: 0 auto;
            padding: 2rem 1.5rem;
            position: relative;
            z-index: 1;
        }

        /* ── Status bar ──────────────────────────────────── */
        #status-bar {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 1.75rem;
            color: var(--muted);
            font-size: 0.85rem;
            min-height: 24px;
        }

        .pulse-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--accent);
            animation: pulseDot 1.2s ease-in-out infinite;
            flex-shrink: 0;
            transition: background 0.3s ease;
        }

        /* Faster pulse during calculating phase */
        .pulse-dot.fast {
            animation-duration: 0.35s;
        }

        @@keyframes pulseDot {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.3; transform: scale(0.65); }
        }

        /* ── Hero result card ────────────────────────────── */
        #hero-display {
            display: none;
            opacity: 0;
            margin-bottom: 2rem;
            border-radius: 16px;
            border: 2px solid var(--border);
            padding: 2rem 2.5rem;
            text-align: center;
            position: relative;
            overflow: hidden;
            background: linear-gradient(135deg, var(--surface) 0%, var(--bg) 100%);
            transition: opacity 0.7s ease, border-color 0.5s ease, box-shadow 0.5s ease;
        }

        /* Pre-reveal tension: faint ghost of the card glowing in */
        #hero-display.building {
            opacity: 0.25;
            border-color: rgba(99, 102, 241, 0.45);
            box-shadow: 0 0 60px rgba(99, 102, 241, 0.1);
        }

        /* Multi-bounce entrance animation */
        #hero-display.revealed {
            animation: cardReveal 1.4s cubic-bezier(0.22, 0.61, 0.36, 1) forwards;
        }

        /* Brief bright flash across the card face on reveal */
        #hero-display.revealed::after {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: 14px;
            background: rgba(255,255,255,0.2);
            animation: revealFlash 0.55s ease-out forwards;
            pointer-events: none;
            z-index: 10;
        }

        @@keyframes cardReveal {
            0%   { opacity: 0.25; transform: translateY(0) scale(1); }
            28%  { opacity: 1;    transform: translateY(-20px) scale(1.04); }
            52%  { transform: translateY(9px) scale(0.987); }
            72%  { transform: translateY(-6px) scale(1.013); }
            88%  { transform: translateY(2px) scale(0.998); }
            100% { opacity: 1;    transform: translateY(0) scale(1); }
        }

        @@keyframes revealFlash {
            0%   { opacity: 1; }
            100% { opacity: 0; }
        }

        /* ── Medal row ───────────────────────────────────── */
        .tier-medals {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.75rem;
            margin-bottom: 0.5rem;
        }

        .tier-medal {
            font-size: 4.5rem;
            line-height: 1;
            display: inline-block;
            opacity: 0;
            transform: translateY(-28px) scale(0.5);
        }

        .tier-medal.drop {
            animation: medalDrop 0.85s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
        }

        @@keyframes medalDrop {
            0%   { opacity: 0; transform: translateY(-55px) scale(0.3); }
            50%  { opacity: 1; transform: translateY(14px) scale(1.4); }
            70%  { transform: translateY(-8px) scale(0.92); }
            85%  { transform: translateY(6px) scale(1.07); }
            100% { opacity: 1; transform: translateY(0) scale(1); }
        }

        .hero-tier-name {
            font-size: 3.5rem;
            font-weight: 900;
            letter-spacing: -0.03em;
            line-height: 1;
        }

        /* Stamp entrance for tier name */
        .hero-tier-name.stamp {
            animation: tierStamp 0.55s cubic-bezier(0.22, 0.61, 0.36, 1) forwards;
        }

        @@keyframes tierStamp {
            0%   { transform: scale(1.8); opacity: 0; filter: blur(6px); }
            55%  { transform: scale(0.92); opacity: 1; filter: blur(0); }
            78%  { transform: scale(1.09); }
            100% { transform: scale(1); opacity: 1; }
        }

        .hero-score {
            font-size: 2rem;
            font-weight: 700;
            color: var(--muted);
            margin-top: 0.5rem;
            margin-bottom: 0.5rem;
            transition: color 0.4s ease;
        }

        .hero-detail {
            font-size: 0.9rem;
            color: var(--muted);
        }

        .hero-glow {
            position: absolute;
            inset: 0;
            border-radius: 14px;
            pointer-events: none;
            opacity: 0;
            transition: opacity 0.4s ease 1.1s;
        }

        #hero-display.revealed .hero-glow {
            opacity: 1;
            animation: glowPulse 2s ease-in-out 1.1s infinite alternate;
        }

        @@keyframes glowPulse {
            from { box-shadow: inset 0 0 40px var(--tier-color, transparent); }
            to   { box-shadow: inset 0 0 80px var(--tier-color, transparent); }
        }

        /* Spark burst (Hero tier only) */
        .sparks {
            position: absolute;
            inset: 0;
            pointer-events: none;
            overflow: hidden;
        }

        .spark {
            position: absolute;
            width: 6px;
            height: 6px;
            border-radius: 50%;
            animation: sparkFly 0.8s ease-out forwards;
            opacity: 0;
        }

        @@keyframes sparkFly {
            0%   { opacity: 1; transform: translate(0, 0) scale(1); }
            100% { opacity: 0; transform: translate(var(--tx), var(--ty)) scale(0); }
        }

        /* ── Calendar containers ─────────────────────────── */
        #calendars {
            display: flex;
            align-items: flex-start;
            flex-wrap: wrap;
            justify-content: center;
        }

        .month-card {
            flex: 1 1 280px;
            min-width: 0;
            max-width: 420px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 1.25rem;
            box-shadow: 0 4px 24px rgba(0,0,0,0.35);
        }

        /* ── Calendar section label ─────────────────────── */
        .section-label {
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--muted);
            margin-bottom: 0.85rem;
            opacity: 0.7;
        }

        #prev-month {
            max-width: 0;
            overflow: hidden;
            padding: 0;
            border-width: 0;
            margin-right: 0;
            opacity: 0;
            transition: max-width 0.6s ease, padding 0.6s ease, border-width 0.6s ease,
                        margin-right 0.6s ease, opacity 0.5s ease;
        }

        #prev-month.visible {
            max-width: 420px;
            padding: 1.25rem;
            border-width: 1px;
            margin-right: 1.5rem;
            opacity: 1;
            overflow: visible;
        }

        @@media (max-width: 620px) {
            #calendars { flex-direction: column; align-items: stretch; }
            .month-card { max-width: none; width: 100%; }
            #curr-month { order: -1; }

            #prev-month {
                max-width: none;
                max-height: 0;
                margin-right: 0;
                transition: max-height 0.6s ease, padding 0.6s ease, border-width 0.6s ease,
                            margin-top 0.6s ease, opacity 0.5s ease;
            }

            #prev-month.visible {
                max-width: none;
                max-height: 600px;
                margin-right: 0;
                margin-top: 1.5rem;
            }
        }

        .month-header {
            font-size: 0.9rem;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 0.75rem;
            letter-spacing: 0.02em;
        }

        /* ── Calendar grid ───────────────────────────────── */
        .cal-grid {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 3px;
        }

        .day-label {
            text-align: center;
            font-size: 10px;
            font-weight: 600;
            color: var(--muted);
            padding: 4px 0 6px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .day-cell {
            position: relative;
            aspect-ratio: 1;
            border-radius: 7px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        .day-cell.active {
            background: var(--surface2);
            border: 1px solid var(--border);
            transition: background 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;
        }

        .day-cell.inactive { opacity: 0.18; }
        .day-cell.empty {}

        /* 1. Scanning pulse — background animation stays inside cell bounds */
        .day-cell.scanning {
            border-color: var(--accent) !important;
            animation: scanPulse 0.85s ease-in-out infinite;
        }

        @@keyframes scanPulse {
            0%, 100% { background: rgba(99,102,241,0.10); box-shadow: inset 0 0 8px rgba(99,102,241,0.3); }
            50%       { background: rgba(99,102,241,0.22); box-shadow: inset 0 0 16px rgba(99,102,241,0.5); }
        }

        /* 2. Golden glow for fully-captioned days */
        .day-cell.starred {
            background: rgba(245,158,11,0.10) !important;
            border-color: rgba(245,158,11,0.45) !important;
            box-shadow: inset 0 0 14px rgba(245,158,11,0.18) !important;
        }

        /* 7. Shimmer sweep on starred (fully-captioned) days */
        .day-cell.starred::before {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: 6px;
            background: linear-gradient(90deg, transparent 0%, rgba(255,220,80,0.28) 50%, transparent 100%);
            background-size: 200% 100%;
            animation: shimmerSweep 2.4s ease-in-out infinite;
            pointer-events: none;
            z-index: 0;
        }

        @@keyframes shimmerSweep {
            0%   { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }

        /* 4. White flash on each image increment */
        .day-cell.flash::after {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: 6px;
            background: rgba(255,255,255,0.3);
            animation: cellFlash 0.22s ease-out forwards;
            pointer-events: none;
        }

        @@keyframes cellFlash {
            0%   { opacity: 1; }
            100% { opacity: 0; }
        }

        .day-num {
            position: absolute;
            top: 4px;
            left: 6px;
            font-size: 9px;
            color: var(--muted);
            line-height: 1;
        }

        /* Star icon */
        .star {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) scale(0);
            font-size: 28px;
            line-height: 1;
            opacity: 0;
            pointer-events: none;
            z-index: 0;
        }

        .star.show {
            animation: starBurst 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
        }

        @@keyframes starBurst {
            0%   { opacity: 0;    transform: translate(-50%,-50%) scale(0)    rotate(-20deg);
                   filter: drop-shadow(0 0 0px #f59e0b); }
            45%  { opacity: 1;    transform: translate(-50%,-50%) scale(1.9)  rotate(10deg);
                   filter: drop-shadow(0 0 14px #f59e0b); }
            75%  { opacity: 0.75; transform: translate(-50%,-50%) scale(1.05) rotate(2deg);
                   filter: drop-shadow(0 0 5px #f59e0b80); }
            100% { opacity: 0.5;  transform: translate(-50%,-50%) scale(0.82) rotate(0deg);
                   filter: drop-shadow(0 0 2px #f59e0b40); }
        }

        .count-wrap {
            position: relative;
            z-index: 1;
            font-size: 1rem;
            font-weight: 800;
            color: #fff;
            min-height: 1.2em;
            text-shadow: 0 1px 4px rgba(0,0,0,0.95), 0 0 8px rgba(0,0,0,0.6);
        }

        .count:empty::before { content: '·'; color: transparent; }

        /* 5. Slot-machine roll on count increment */
        .day-cell.pop .count-wrap {
            animation: countRoll 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        @@keyframes countRoll {
            0%   { transform: translateY(8px) scale(0.8); opacity: 0.5; }
            60%  { transform: translateY(-2px) scale(1.5); opacity: 1; }
            100% { transform: translateY(0) scale(1); opacity: 1; }
        }

        /* ── Error / not-found ───────────────────────────── */
        .error-card {
            background: color-mix(in srgb, #ef4444 10%, var(--surface));
            border: 1px solid #ef4444;
            border-radius: 12px;
            padding: 1.5rem 2rem;
            color: #ef4444;
            margin-bottom: 1.5rem;
        }

        .error-card h2 { font-size: 1rem; margin-bottom: 0.25rem; }
        .error-card p { font-size: 0.85rem; opacity: 0.85; }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            margin-top: 1rem;
            color: var(--muted);
            font-size: 0.85rem;
            text-decoration: none;
            padding: 0.4rem 0.8rem;
            border: 1px solid var(--border);
            border-radius: 8px;
            transition: border-color 0.15s, color 0.15s, background 0.15s;
        }

        .back-link:hover {
            color: var(--accent);
            border-color: var(--accent);
            background: rgba(99,102,241,0.07);
        }

        /* ── Responsive tweaks ───────────────────────────── */
        @@media (max-width: 480px) {
            main { padding: 1.25rem 1rem; }
            #hero-display { padding: 1.5rem 1.25rem; }
            .hero-tier-name { font-size: 2.5rem; }
            .tier-medal { font-size: 3rem; }
            .hero-score { font-size: 1.25rem; }
            .star { font-size: 20px; }
            .count-wrap { font-size: 0.85rem; }
            .day-num { font-size: 8px; }
        }

        /* ── Light theme ─────────────────────────────────── */
        [data-theme="light"] {
            color-scheme: light;
            --bg: #f0f2f8;
            --surface: #ffffff;
            --surface2: #eef0f7;
            --border: #d4d9ea;
            --text: #111827;
            --muted: #6b7280;
        }

        [data-theme="light"] .month-card {
            box-shadow: 0 4px 24px rgba(0,0,0,0.08);
        }

        /* Calendar count text in light mode */
        [data-theme="light"] .count-wrap {
            color: var(--text);
            text-shadow: 0 1px 3px rgba(255,255,255,0.85);
        }

        /* ── Theme toggle button ─────────────────────────── */
        .theme-toggle {
            margin-left: auto;
            flex-shrink: 0;
            background: transparent;
            border: 1px solid var(--border);
            border-radius: 8px;
            color: var(--muted);
            cursor: pointer;
            padding: 0.35rem 0.45rem;
            display: flex;
            align-items: center;
            justify-content: center;
            line-height: 1;
            transition: border-color 0.15s, color 0.15s;
        }

        .theme-toggle:hover { border-color: var(--accent); color: var(--accent); }

        .theme-toggle .sun { display: block; }
        .theme-toggle .moon { display: none; }
        [data-theme="light"] .theme-toggle .sun { display: none; }
        [data-theme="light"] .theme-toggle .moon { display: block; }
    </style>
</head>
<script>
function toggleTheme() {
    var t = document.documentElement.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
    document.documentElement.setAttribute('data-theme', t);
    localStorage.setItem('altheroes_theme', t);
}
</script>
<body>

<div id="bg-glow"></div>

<header>
    <a class="brand" href="/">AltHeroes</a>
    <span class="header-query">@Model.Q</span>
    <button class="theme-toggle" onclick="toggleTheme()" aria-label="Toggle theme">
        <svg class="sun" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        <svg class="moon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
    </button>
</header>

<main>

@if (Model.Error is not null)
{
    <div class="error-card">
        <h2>Not found</h2>
        <p>@Model.Error</p>
    </div>
    <a class="back-link" href="/">← Try another handle</a>
}
else if (Model.Did is not null)
{
    <!-- Status bar -->
    <div id="status-bar">
        <div class="pulse-dot" id="pulse-dot"></div>
        <span id="status-text">Loading posts for @Model.Q…</span>
    </div>

    <!-- Result card (revealed on done) -->
    <div id="hero-display" aria-live="polite">
        <div class="hero-glow" id="hero-glow"></div>
        <div class="sparks" id="sparks"></div>
        <div class="tier-medals">
            <span class="tier-medal" id="medal-left"></span>
            <div class="hero-tier-name" id="hero-tier"></div>
            <span class="tier-medal" id="medal-right"></span>
        </div>
        <div class="hero-score" id="hero-score"></div>
        <div class="hero-detail" id="hero-detail"></div>
    </div>

    <!-- Calendar grid -->
    <div class="section-label">Recent activity</div>
    <div id="calendars">
        <div class="month-card" id="prev-month">
            <div class="month-header" id="prev-month-header"></div>
            <div class="cal-grid" id="prev-month-grid"></div>
        </div>
        <div class="month-card" id="curr-month">
            <div class="month-header" id="curr-month-header"></div>
            <div class="cal-grid" id="curr-month-grid"></div>
        </div>
    </div>

    <script>
    (() => {
        const DID = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Did));
        const WINDOW_DAYS = @Model.WindowDays;

        // ── Date helpers ──────────────────────────────────────────────────
        const now = new Date();
        const todayUTC = new Date(Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate()));
        const cutoffUTC = new Date(todayUTC.getTime() - WINDOW_DAYS * 86400000);

        const MONTH_NAMES = ['January','February','March','April','May','June',
                             'July','August','September','October','November','December'];
        const DAY_LABELS = ['Su','Mo','Tu','We','Th','Fr','Sa'];

        let currYear = todayUTC.getUTCFullYear();
        let currMonth = todayUTC.getUTCMonth();
        let prevYear = currYear, prevMonth = currMonth - 1;
        if (prevMonth < 0) { prevMonth = 11; prevYear--; }

        function pad(n) { return String(n).padStart(2, '0'); }
        function dateStr(y, m, d) { return `${y}-${pad(m+1)}-${pad(d)}`; }
        function isInWindow(y, m, d) {
            const t = Date.UTC(y, m, d);
            return t >= cutoffUTC.getTime() && t <= todayUTC.getTime();
        }

        // ── Calendar generation ───────────────────────────────────────────
        function buildCalendar(year, month, headerId, gridId) {
            document.getElementById(headerId).textContent = `${MONTH_NAMES[month]} ${year}`;
            const grid = document.getElementById(gridId);

            let html = DAY_LABELS.map(d => `<div class="day-label">${d}</div>`).join('');

            const firstDow = new Date(Date.UTC(year, month, 1)).getUTCDay();
            for (let i = 0; i < firstDow; i++) html += `<div class="day-cell empty"></div>`;

            const days = new Date(Date.UTC(year, month + 1, 0)).getUTCDate();
            for (let d = 1; d <= days; d++) {
                const ds = dateStr(year, month, d);
                if (isInWindow(year, month, d)) {
                    html += `<div class="day-cell active" data-date="${ds}">` +
                            `<span class="day-num">${d}</span>` +
                            `<div class="star">&#11088;</div>` +
                            `<div class="count-wrap"><span class="count"></span></div>` +
                            `</div>`;
                } else {
                    html += `<div class="day-cell inactive"><span class="day-num">${d}</span></div>`;
                }
            }
            grid.innerHTML = html;
        }

        buildCalendar(currYear, currMonth, 'curr-month-header', 'curr-month-grid');
        buildCalendar(prevYear, prevMonth, 'prev-month-header', 'prev-month-grid');

        // ── SSE stream ────────────────────────────────────────────────────
        const source = new EventSource('/stream/' + encodeURIComponent(DID));
        let prevMonthVisible = false;
        let imageCount = 0;
        let scanningCell = null; // 1. tracks currently highlighted cell

        source.addEventListener('image', e => {
            const { date } = JSON.parse(e.data);
            imageCount++;

            // Reveal previous month card when we first hit a date in it
            if (!prevMonthVisible && date.startsWith(`${prevYear}-${pad(prevMonth + 1)}`)) {
                document.getElementById('prev-month').classList.add('visible');
                prevMonthVisible = true;
            }

            const cell = document.querySelector(`[data-date="${date}"]`);
            if (!cell) return;

            // 1. Move scanning highlight to this cell
            if (scanningCell !== cell) {
                scanningCell?.classList.remove('scanning');
                cell.classList.add('scanning');
                scanningCell = cell;
            }

            const countEl = cell.querySelector('.count');
            if (!countEl) return;
            countEl.textContent = (parseInt(countEl.textContent) || 0) + 1;

            // 4. Flash + 5. roll — remove then re-add to retrigger animation
            cell.classList.remove('pop', 'flash');
            void cell.offsetWidth;
            cell.classList.add('pop', 'flash');

            document.getElementById('status-text').textContent =
                `Analyzed ${imageCount} image${imageCount !== 1 ? 's' : ''}…`;
        });

        source.addEventListener('day_complete', e => {
            const { date, allCompliant } = JSON.parse(e.data);
            const cell = document.querySelector(`[data-date="${date}"]`);
            if (!cell) return;

            // 1. Remove scanning ring from completed day
            cell.classList.remove('scanning');
            if (scanningCell === cell) scanningCell = null;

            if (allCompliant) {
                // 2. Persistent golden glow for fully-captioned days
                cell.classList.add('starred');
                cell.querySelector('.star')?.classList.add('show');
            }
        });

        // 3. Pre-reveal tension: accelerate pulse, ghost the result card
        source.addEventListener('calculating', () => {
            document.getElementById('pulse-dot')?.classList.add('fast');
            document.getElementById('status-text').textContent = 'Calculating result…';

            const card = document.getElementById('hero-display');
            card.style.display = 'block';
            void card.offsetWidth;
            card.classList.add('building');
        });

        source.addEventListener('done', e => {
            source.close();
            // Clear any remaining scanning ring
            scanningCell?.classList.remove('scanning');
            scanningCell = null;
            showResult(JSON.parse(e.data));
        });

        source.onerror = () => {
            source.close();
            document.getElementById('status-text').textContent = 'Connection error — please reload.';
            document.getElementById('pulse-dot').style.background = '#ef4444';
        };

        // ── Final result reveal ───────────────────────────────────────────
        const TIER_COLORS = {
            None:   '#6b7280',
            Bronze: '#cd7f32',
            Silver: '#94a3b8',
            Gold:   '#f59e0b',
            Hero:   '#a855f7'
        };

        const TIER_MEDALS = {
            None:   '',
            Bronze: '🥉',
            Silver: '🥈',
            Gold:   '🥇',
            Hero:   '👑'
        };

        // For Hero the two sides are different — crown left, trophy right
        const TIER_MEDALS_RIGHT = { ...TIER_MEDALS, Hero: '🏆' };

        // 6. Tier-reactive background gradients
        const TIER_BG = {
            Bronze: 'radial-gradient(ellipse at 50% 0%, rgba(205,127,50,0.14) 0%, transparent 65%)',
            Silver: 'radial-gradient(ellipse at 50% 0%, rgba(148,163,184,0.14) 0%, transparent 65%)',
            Gold:   'radial-gradient(ellipse at 50% 0%, rgba(245,158,11,0.14) 0%, transparent 65%)',
            Hero:   'radial-gradient(ellipse at 50% 0%, rgba(168,85,247,0.20) 0%, transparent 65%)'
        };

        function showResult(data) {
            document.getElementById('status-bar').remove();

            const color = TIER_COLORS[data.tier] ?? '#6b7280';
            const card = document.getElementById('hero-display');
            card.style.borderColor = color;
            card.style.setProperty('--tier-color', color + '30');

            // Pre-populate content (hidden; staggered in below)
            const tierEl = document.getElementById('hero-tier');
            tierEl.textContent = data.tier; // pre-fill keeps layout stable
            tierEl.style.color = color;
            tierEl.style.opacity = '0';

            const scoreEl = document.getElementById('hero-score');
            scoreEl.style.opacity = '0';
            scoreEl.style.color = color;

            const detailEl = document.getElementById('hero-detail');
            if (data.totalImagePosts === 0) {
                detailEl.textContent = 'Start adding alt text to your images and you\'ll earn a medal before you know it!';
            } else if (data.tier === 'None') {
                detailEl.textContent = `${data.compliantPosts} of ${data.totalImagePosts} image posts include alt text — keep it up and you\'ll earn a medal before you know it!`;
            } else {
                detailEl.textContent = `${data.compliantPosts} of ${data.totalImagePosts} image posts include alt text`;
            }
            detailEl.style.opacity = '0';

            // Medals
            const medalL = TIER_MEDALS[data.tier] ?? '';
            const medalR = TIER_MEDALS_RIGHT[data.tier] ?? '';
            document.getElementById('medal-left').textContent = medalL;
            document.getElementById('medal-right').textContent = medalR;

            // ── Stage 1: Card bounces in ──────────────────────────────────
            card.style.display = 'block';
            card.classList.remove('building');
            void card.offsetWidth;
            card.classList.add('revealed');

            // ── Stage 2: Score counts in (T+520ms) ───────────────────────
            setTimeout(() => {
                scoreEl.style.transition = 'opacity 0.3s ease';
                detailEl.style.transition = 'opacity 0.3s ease 0.12s';
                if (data.totalImagePosts > 0) {
                    scoreEl.style.opacity = '1';
                    animateScore(scoreEl, data.score, 900);
                } else {
                    scoreEl.textContent = '—';
                    scoreEl.style.opacity = '1';
                }
                detailEl.style.opacity = '1';
            }, 520);

            // ── Stage 3: Tier name stamps in (T+1050ms) ──────────────────
            setTimeout(() => {
                if (data.tier === 'Hero') {
                    stampHeroSlot(tierEl, color);
                } else {
                    tierEl.style.opacity = '1';
                    void tierEl.offsetWidth;
                    tierEl.classList.add('stamp');
                    // Sparks for medal tiers
                    const n = { Bronze: 10, Silver: 14, Gold: 20 }[data.tier];
                    if (n) launchSparks(card, color, n);
                }
            }, 1050);

            // ── Stage 4: Medals drop in ───────────────────────────────────
            // Hero medals wait until after the slot machine lands (~2400ms)
            const medalDelay = data.tier === 'Hero' ? 2500 : 1480;
            if (medalL) {
                setTimeout(() => {
                    document.getElementById('medal-left').classList.add('drop');
                    setTimeout(() =>
                        document.getElementById('medal-right').classList.add('drop'), 130);
                }, medalDelay);
            }

            // ── Tier-reactive background ──────────────────────────────────
            const grad = TIER_BG[data.tier];
            if (grad) {
                const bg = document.getElementById('bg-glow');
                bg.style.background = grad;
                setTimeout(() => { bg.style.opacity = '1'; }, 200);
            }
        }

        // Score counter — eases up from 0 to target over duration ms
        function animateScore(el, target, duration) {
            const t0 = performance.now();
            (function tick(now) {
                const p = Math.min((now - t0) / duration, 1);
                const eased = 1 - Math.pow(1 - p, 3);
                el.textContent = (eased * target).toFixed(1) + '%';
                if (p < 1) requestAnimationFrame(tick);
                else el.textContent = target.toFixed(1) + '%';
            })(t0);
        }

        // Hero-only: slot machine spins through tiers then SLAMS onto Hero
        function stampHeroSlot(tierEl, color) {
            const names = ['Bronze', 'Silver', 'Gold', 'Hero'];
            let idx = 0, interval = 70;
            tierEl.style.opacity = '1';

            function tick() {
                tierEl.textContent = names[idx % names.length];
                tierEl.style.color = TIER_COLORS[names[idx % names.length]];
                idx++;
                interval = Math.min(interval * 1.2, 480);
                if (interval >= 460) {
                    setTimeout(() => {
                        tierEl.textContent = 'Hero';
                        tierEl.style.color = color;
                        tierEl.classList.add('stamp');
                        heroFlash();
                        setTimeout(() => heroJackpot(
                            document.getElementById('hero-display'), color), 60);
                    }, interval);
                } else {
                    setTimeout(tick, interval);
                }
            }
            tick();
        }

        // Full-screen white flash for the jackpot moment
        function heroFlash() {
            const flash = document.createElement('div');
            flash.style.cssText =
                'position:fixed;inset:0;background:#fff;opacity:0;pointer-events:none;z-index:9999;transition:none';
            document.body.appendChild(flash);
            void flash.offsetWidth;
            flash.style.opacity = '0.7';
            setTimeout(() => {
                flash.style.transition = 'opacity 0.75s ease';
                flash.style.opacity = '0';
                flash.addEventListener('transitionend', () => flash.remove());
            }, 65);
        }

        // Four waves of multi-colour sparks for the jackpot
        function heroJackpot(card, color) {
            const palette = ['#a855f7', '#f59e0b', '#ec4899', '#ffffff', '#818cf8'];
            for (let w = 0; w < 4; w++) {
                setTimeout(() => launchSparks(card, palette[w % palette.length], 28, w * 45), w * 220);
            }
        }

        function launchSparks(card, color, count = 24, baseDelayMs = 0) {
            const container = document.getElementById('sparks');
            const cx = card.offsetWidth / 2;
            const cy = card.offsetHeight / 2;
            for (let i = 0; i < count; i++) {
                const spark = document.createElement('div');
                spark.className = 'spark';
                spark.style.background = color;
                spark.style.left = cx + 'px';
                spark.style.top = cy + 'px';
                const angle = (i / count) * 2 * Math.PI + (Math.random() - 0.5) * 0.6;
                const dist = 70 + Math.random() * 130;
                spark.style.setProperty('--tx', Math.cos(angle) * dist + 'px');
                spark.style.setProperty('--ty', Math.sin(angle) * dist + 'px');
                spark.style.animationDelay = (baseDelayMs / 1000 + Math.random() * 0.35) + 's';
                container.appendChild(spark);
                spark.addEventListener('animationend', () => spark.remove());
            }
        }
        function toggleTheme() {
            var t = document.documentElement.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
            document.documentElement.setAttribute('data-theme', t);
            localStorage.setItem('altheroes_theme', t);
        }
    })();
    </script>
}
else
{
    <script>location.href = '/';</script>
}

</main>
