@page "/admin/subscribers/{did}"
@model AltTextBot.Web.Pages.Admin.SubscriberDetailModel
@{
    ViewData["Title"] = "Subscriber Detail";
}
<div class="container mt-4">
    <a href="/admin/subscribers" class="btn btn-outline-secondary btn-sm mb-3">&#8592; Subscribers</a>
    @if (TempData["Success"] is string successMsg)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @successMsg
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] is string errorMsg)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @errorMsg
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (Model.Subscriber is null)
    {
        <div class="alert alert-warning">Subscriber not found.</div>
    }
    else
    {
        <div class="card mb-4">
            <div class="card-header">
                <h2 class="h4 mb-0">@Model.Subscriber.Handle</h2>
                <small class="text-muted">@Model.Subscriber.Did</small>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3">
                        <strong>Status:</strong>
                        @if (Model.Subscriber.Status == AltTextBot.Domain.Enums.SubscriberStatus.Active)
                        {
                            <span class="badge bg-success ms-1">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary ms-1">Deactivated</span>
                        }
                    </div>
                    <div class="col-md-3">
                        <strong>Current Tier:</strong> @(Model.CurrentTier?.ToString() ?? "None")
                    </div>
                    <div class="col-md-3">
                        <strong>Score:</strong> @(Model.Score is not null ? $"{Model.Score.ScorePercent:F1}%" : "N/A")
                    </div>
                    <div class="col-md-3">
                        <strong>Last Scored:</strong> @(Model.Subscriber.LastScoredAt?.ToString("yyyy-MM-dd HH:mm") is string d ? $"{d} UTC" : "Never")
                    </div>
                </div>
            </div>
            <div class="card-footer">
                <form method="post" asp-page-handler="Rescore" class="d-inline">
                    <input type="hidden" name="Did" value="@Model.Subscriber.Did" />
                    <button type="submit" class="btn btn-warning btn-sm">Rescore Now</button>
                </form>
                @if (Model.Subscriber.Status == AltTextBot.Domain.Enums.SubscriberStatus.Active)
                {
                    <form method="post" asp-page-handler="Deactivate" class="d-inline ms-2">
                        <input type="hidden" name="Did" value="@Model.Subscriber.Did" />
                        <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Deactivate this subscriber?')">Deactivate</button>
                    </form>
                }
                else
                {
                    <form method="post" asp-page-handler="Reactivate" class="d-inline ms-2">
                        <input type="hidden" name="Did" value="@Model.Subscriber.Did" />
                        <button type="submit" class="btn btn-success btn-sm">Reactivate</button>
                    </form>
                }
            </div>
        </div>

        <h5>Recent Audit Events</h5>
        @if (Model.AuditLogs.Count == 0)
        {
            <p class="text-muted">No audit events recorded for this subscriber.</p>
        }
        else
        {
            <table class="table table-sm">
                <thead>
                    <tr><th>Time</th><th>Event</th><th>Details</th></tr>
                </thead>
                <tbody>
                    @foreach (var log in Model.AuditLogs)
                    {
                        <tr>
                            <td><small>@log.Timestamp.ToString("yyyy-MM-dd HH:mm:ss") UTC</small></td>
                            <td><span class="badge bg-info text-dark">@log.EventType</span></td>
                            <td style="max-width: 350px;"><small style="overflow-wrap: break-word; word-break: break-word;">@log.Details</small></td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    }
</div>
