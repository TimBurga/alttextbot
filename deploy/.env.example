# Copy to deploy/.env and fill in real values.
# This file is a template only — deploy/.env is gitignored.

# Admin panel password — must not be "changeme" or the web app won't start
ADMIN_PASSWORD=change-me-to-something-strong

# Shared secret between web and bot (any random string; unused until bot is enabled)
ADMIN_API_KEY=change-me-to-a-random-secret

# ── SigNoz (telemetry dashboard) ──────────────────────────────────────────────
# SigNoz frontend is available at http://localhost:3301 (SSH tunnel or reverse proxy required)
# No configuration needed — services connect via internal Docker network

# ── Bot credentials (only needed when the bot service is uncommented) ─────────
# BOT_DID=did:plc:...
# BOT_HANDLE=yourbot.bsky.social
# BOT_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# LABELER_DID=did:plc:...
# LABELER_OZONE_URL=https://your-ozone-instance.example.com
# JETSTREAM_URL=wss://jetstream2.us-east.bsky.network/subscribe
