<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] is "Home" ? "Alt Heroes" : $"{ViewData["Title"]} - Alt Heroes")</title>
    <meta name="description" content="Alt Heroes encourages better image accessibility on Bluesky by rewarding users who consistently add alt text with tiered labels." />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script>
        // Apply saved theme before first paint to prevent flash
        (function () {
            var t = localStorage.getItem('alttext-theme') || 'light';
            document.documentElement.setAttribute('data-bs-theme', t);
        }());
    </script>
</head>
<body>
    <a href="#main-content" class="visually-hidden-focusable">Skip to main content</a>
    <nav class="navbar navbar-expand-lg bg-dark" data-bs-theme="dark">
        <div class="container">
            <a class="navbar-brand" href="/">Alt Heroes</a>
            <button class="btn btn-outline-light btn-sm ms-auto"
                    id="theme-toggle"
                    aria-label="Switch to dark mode"
                    aria-pressed="false">
                🌙
            </button>
        </div>
    </nav>
    <main id="main-content">
        @RenderBody()
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function () {
            var btn = document.getElementById('theme-toggle');

            function applyTheme(theme) {
                document.documentElement.setAttribute('data-bs-theme', theme);
                var dark = theme === 'dark';
                btn.textContent = dark ? '☀\uFE0F' : '🌙';
                btn.setAttribute('aria-label', dark ? 'Switch to light mode' : 'Switch to dark mode');
                btn.setAttribute('aria-pressed', dark ? 'true' : 'false');
            }

            // Sync button state with the theme already applied in <head>
            applyTheme(document.documentElement.getAttribute('data-bs-theme') || 'light');

            btn.addEventListener('click', function () {
                var next = document.documentElement.getAttribute('data-bs-theme') === 'dark' ? 'light' : 'dark';
                localStorage.setItem('alttext-theme', next);
                applyTheme(next);
            });
        }());
    </script>
</body>
</html>
